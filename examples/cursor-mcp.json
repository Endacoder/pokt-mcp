{
  "mcpServers": {
    "pokt-mcp": {
      "command": "node",
      "args": ["packages/mcp-server/dist/index.js"],
      "env": {
        "POCKET_DEFAULT_CHAIN": "eth",
        "REQUIRE_CONFIRMATION": "true",
        "ALLOW_LOCAL_SIGNER": "false",
        "MAX_SEND_VALUE_ETH": "1.0",
        "WALLET_ALLOWED_CHAINS": "eth,base,arb-one,poly,opt,avax",
        "RPC_METHOD_DENYLIST": "personal_importRawKey,eth_sign",
        "FEATURE_NL_LLM": "true",
        "FEATURE_AGENT_LOOP": "true"
      }
    },
    "intent-mcp": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.metalift.ai/mcp",
        "--header",
        "Authorization: Bearer ${INTENT_MCP_API_KEY}"
      ],
      "env": {
        "INTENT_MCP_API_KEY": "your-api-key"
      }
    }
  }
}
