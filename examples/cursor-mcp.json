{
  "mcpServers": {
    "pokt-mcp": {
      "command": "node",
      "args": ["packages/mcp-server/dist/index.js"],
      "env": {
        "POCKET_DEFAULT_CHAIN": "eth",
        "REQUIRE_CONFIRMATION": "true",
        "ALLOW_LOCAL_SIGNER": "false",
        "MAX_SEND_VALUE_ETH": "1.0"
      }
    }
  }
}
