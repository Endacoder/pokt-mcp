FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
COPY apps/web ./apps/web
COPY packages/shared ./packages/shared
RUN npm ci
WORKDIR /app/apps/web
RUN npm run build

FROM node:20-alpine
WORKDIR /app
COPY --from=build /app/apps/web /app
ENV PORT=3000
EXPOSE 3000
CMD ["npm", "start"]
