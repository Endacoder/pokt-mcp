# Pocket Network
POCKET_PORTAL_BASE=
POCKET_DEFAULT_CHAIN=
FALLBACK_RPC_URLS=

# Wallet
WALLETCONNECT_PROJECT_ID=
WALLET_ALLOWED_CHAINS=
WALLET_SESSION_TIMEOUT_MS=

# Policy
MAX_SEND_VALUE_ETH=
MAX_SESSION_SEND_TOTAL_ETH=
REQUIRE_CONFIRMATION=
ALLOW_LOCAL_SIGNER=
RPC_METHOD_DENYLIST=
POKT_AUDIT_DIR=

# Rate limiting (per client session or IP)
RATE_LIMIT_ENABLED=
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_REQUESTS_PER_MINUTE=
RATE_LIMIT_CHAT_PER_MINUTE=

# Dev-only local signer (never enable in production)
# PRIVATE_KEY=0x...

# Optional NL parsing (template-first; LLM fallback when FEATURE_NL_LLM=true)
# Template-only mode handles common RPC queries (blocks, balances, gas) and meta questions ("what model are you").
# Set FEATURE_NL_LLM=true for broader natural language beyond templates.
FEATURE_NL_LLM=
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
# LiteLLM proxy (OpenAI-compatible API, e.g. http://localhost:4000)
LLM_PROVIDER=
# Required for LiteLLM — must match a model available on your proxy (curl $LITELLM_BASE_URL/v1/models)
LLM_MODEL=
LITELLM_BASE_URL=
LITELLM_API_KEY=
# API (default 3001; use 3002 if Grafana or another service uses 3001)
PORT=
HOST=

# Web (apps/web)
# Production (Docker / Cloudflare tunnel): use /api — Next.js rewrites proxy to the API container
# Local dev: use http://127.0.0.1:5001 or http://localhost:5001
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WC_PROJECT_ID=

# MCP SSE endpoint (optional — for Settings → MCP connect in the web UI)
NEXT_PUBLIC_MCP_SSE_URL=

# Public URL (set automatically by ./scripts/setup-cloudflare-tunnel.sh)
PUBLIC_APP_URL=

# Cloudflare Tunnel (pokt.metalift.ai)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_NAME=
CLOUDFLARE_APP_HOSTNAME=
CLOUDFLARE_APP_SERVICE=
