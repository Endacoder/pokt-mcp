# Pocket Network
POCKET_PORTAL_BASE=https://api.pocket.network
POCKET_DEFAULT_CHAIN=eth
FALLBACK_RPC_URLS=

# Wallet
WALLETCONNECT_PROJECT_ID=
WALLET_ALLOWED_CHAINS=eth,base,arb-one,poly,avax
WALLET_SESSION_TIMEOUT_MS=86400000

# Policy
MAX_SEND_VALUE_ETH=1.0
MAX_SESSION_SEND_TOTAL_ETH=5.0
REQUIRE_CONFIRMATION=true
ALLOW_LOCAL_SIGNER=false
RPC_METHOD_DENYLIST=personal_importRawKey,eth_sign

# Optional NL parsing
OPENAI_API_KEY=
